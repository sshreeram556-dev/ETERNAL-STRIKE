{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" }
      },
      "required": ["uid", "email"]
    },
    "interactions": {
      "title": "Interaction",
      "description": "User interaction with ads or services",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Reference to user" },
        "type": { "type": "string", "enum": ["view", "like", "save"], "description": "Interaction type" },
        "category": { "type": "string", "description": "Category of the item interacted with" },
        "timestamp": { "type": "number", "description": "Unix timestamp" }
      },
      "required": ["userId", "type", "category", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    },
    "/users/{userId}/interactions/{interactionId}": {
      "schema": "interactions",
      "description": "Log of user activities for personalization"
    }
  }
}
